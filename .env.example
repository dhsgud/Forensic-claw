# Copy this file to .env before running docker compose if you want to override defaults.

# Change this before real evidence work.
FORENSIC_CLAW_NEO4J_PASSWORD=change-this-password

# Neo4j memory limits used by docker-compose.yml.
FORENSIC_CLAW_NEO4J_HEAP_INITIAL=512m
FORENSIC_CLAW_NEO4J_HEAP_MAX=1G
